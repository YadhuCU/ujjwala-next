generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentType {
  cash
  cheque
}

enum ProductType {
  ARB
  Domestic
  Commercial
  Other
}

enum UserRole {
  Owner
  Office
  Sales
}

model Account {
  id          Int      @id @default(autoincrement())
  uuid        String   @default(uuid())
  username    String   @unique @db.VarChar(40)
  name        String?  @db.VarChar(200)
  password    String
  isActive    Boolean  @default(true) @map("is_active")
  isLogin     Boolean  @default(false) @map("is_login")
  firstLogin  Boolean  @default(false) @map("first_login")
  isSuperuser Boolean  @default(false) @map("is_superuser")
  email       String?  @db.VarChar(50)
  mobile      String?  @db.VarChar(20)
  role        UserRole @default(Sales)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  isDeleted   Boolean  @default(false) @map("is_deleted")

  salesCreated            Sale[]           @relation("SalesCreated")
  domSalesCreated         DomSale[]        @relation("DomSalesCreated")
  arbSalesCreated         ArbSale[]        @relation("ArbSalesCreated")
  commercialSalesCreated  CommercialSale[] @relation("CommercialSalesCreated")
  collectionsCreated      Collection[]     @relation("CollectionsCreated")
  expensesCreated         Expense[]        @relation("ExpensesCreated")

  @@map("accounts")
}

model Location {
  id        Int        @id @default(autoincrement())
  name      String?    @unique @db.VarChar(50)
  district  String?    @db.VarChar(50)
  pincode   String?    @db.VarChar(10)
  locality  String?    @db.VarChar(50)
  isDeleted Boolean    @default(false) @map("is_deleted")
  createdAt DateTime   @default(now()) @map("created_at")
  customers Customer[]

  @@map("locations")
}

model Customer {
  id                     Int               @id @default(autoincrement())
  name                   String?           @unique @db.VarChar(50)
  address                String?
  phone                  String?           @db.VarChar(10)
  locationId             Int?              @map("location_id")
  location               Location?         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  concernedPerson        String?           @map("concerned_person") @db.VarChar(30)
  concernedPersonMobile  String?           @map("concerned_person_mobile") @db.VarChar(30)
  discount               Int?
  gstNumber              String?           @map("gst_number") @db.VarChar(15)
  initialCylinderBalance Int               @default(0) @map("initial_cylinder_balance")
  initialPendingAmount   Decimal           @default(0.00) @map("initial_pending_amount") @db.Decimal(10, 2)
  isDeleted              Boolean           @default(false) @map("is_deleted")
  createdAt              DateTime          @default(now()) @map("created_at")
  sales                  Sale[]
  collections            Collection[]
  rentProducts           RentProduct[]
  rentTransactions       RentTransaction[]
  arbSales               ArbSale[]
  domSales               DomSale[]
  commercialSales        CommercialSale[]
  initialCylinderBalances CustomerInitialCylinderBalance[]

  @@map("customers")
}

model Product {
  id        Int          @id @default(autoincrement())
  name      String?      @unique @db.VarChar(50)
  type      ProductType?
  weight    String?      @db.VarChar(50)
  salePrice Decimal?     @map("sale_price") @db.Decimal(10, 2)

  isDeleted            Boolean                          @default(false) @map("is_deleted")
  createdAt            DateTime                         @default(now()) @map("created_at")
  stocks               Stock[]
  sales                Sale[]
  domSaleItems         DomSaleItem[]
  arbSaleItems         ArbSaleItem[]
  commercialSaleItems  CommercialSaleItem[]
  purchaseItems        PurchaseItem[]
  initialCylinderBalances CustomerInitialCylinderBalance[]

  @@map("products")
}

model Stock {
  id               Int               @id @default(autoincrement())
  batchNo          String?           @unique @map("batch_no") @db.VarChar(50)
  productId        Int?              @map("product_id")
  product          Product?          @relation(fields: [productId], references: [id], onDelete: Cascade)
  invoiceNo        String?           @map("invoice_no") @db.VarChar(50)
  quantity         Int               @default(0)
  productCost      Decimal?          @map("product_cost") @db.Decimal(10, 2)
  vendorId         Int?              @map("vendor_id")
  vendor           Vendor?           @relation(fields: [vendorId], references: [id])
  purchaseId       Int?              @map("purchase_id")
  purchase         Purchase?         @relation(fields: [purchaseId], references: [id])
  isDeleted        Boolean           @default(false) @map("is_deleted")
  createdAt        DateTime          @default(now()) @map("created_at")
  sales                  Sale[]
  domSaleItems           DomSaleItem[]
  arbSaleItems           ArbSaleItem[]
  commercialSaleItems    CommercialSaleItem[]
  rentProducts           RentProduct[]
  rentTransactions       RentTransaction[]

  @@map("stocks")
}

enum SaleType {
  sale
  rent
}

model Sale {
  id               Int               @id @default(autoincrement())
  trNo             String?           @map("tr_no") @db.VarChar(30)
  stockId          Int?              @map("stock_id")
  stock            Stock?            @relation(fields: [stockId], references: [id], onDelete: Cascade)
  customerId       Int?              @map("customer_id")
  customer         Customer?         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  isOffer          Boolean           @default(false) @map("is_offer")
  discount         Int?
  productId        Int?              @map("product_id")
  product          Product?          @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity         Int               @default(0)
  productCost      Decimal?          @map("product_cost") @db.Decimal(10, 2)
  salePrice        Decimal?          @map("sale_price") @db.Decimal(10, 2)
  netTotal         Decimal?          @map("net_total") @db.Decimal(10, 2)
  createdById      Int?              @map("created_by_id")
  createdBy        Account?          @relation("SalesCreated", fields: [createdById], references: [id])
  isDeleted        Boolean           @default(false) @map("is_deleted")
  createdAt        DateTime          @default(now()) @map("created_at")
  rentTransactions RentTransaction[]
  saleType         SaleType          @default(rent) @map("sale_type")
  paymentType      PaymentType       @default(cash) @map("payment_type")

  @@map("sales")
}

model DomSale {
  id          Int           @id @default(autoincrement())
  trNo        String?       @map("tr_no") @db.VarChar(30)
  totalAmount Decimal?      @map("total_amount") @db.Decimal(10, 2)
  customerId  Int?          @map("customer_id")
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  paymentType PaymentType   @default(cash) @map("payment_type")
  discount    Decimal?      @db.Decimal(10, 2)
  notes       String?
  createdById Int?          @map("created_by_id")
  createdBy   Account?      @relation("DomSalesCreated", fields: [createdById], references: [id])
  isDeleted   Boolean       @default(false) @map("is_deleted")
  createdAt   DateTime      @default(now()) @map("created_at")
  paidAmount  Decimal       @default(0) @map("paid_amount") @db.Decimal(10, 2)

  items       DomSaleItem[]
  collections Collection[]

  @@map("dom_sales")
}

model DomSaleItem {
  id        Int      @id @default(autoincrement())
  domSaleId Int      @map("dom_sale_id")
  domSale   DomSale  @relation(fields: [domSaleId], references: [id], onDelete: Cascade)
  stockId   Int?     @map("stock_id")
  stock     Stock?   @relation(fields: [stockId], references: [id])
  productId Int?     @map("product_id")
  product   Product? @relation(fields: [productId], references: [id])
  quantity  Int      @default(0)
  salePrice Decimal? @map("sale_price") @db.Decimal(10, 2)
  netTotal  Decimal? @map("net_total") @db.Decimal(10, 2)

  @@map("dom_sale_items")
}

model Collection {
  id               Int             @id @default(autoincrement())
  trNo             String?         @map("tr_no") @db.VarChar(30)
  customerId       Int?            @map("customer_id")
  customer         Customer?       @relation(fields: [customerId], references: [id])
  domSaleId        Int?            @map("dom_sale_id")
  domSale          DomSale?        @relation(fields: [domSaleId], references: [id])
  arbSaleId        Int?            @map("arb_sale_id")
  arbSale          ArbSale?        @relation(fields: [arbSaleId], references: [id])
  commercialSaleId Int?            @map("commercial_sale_id")
  commercialSale   CommercialSale? @relation(fields: [commercialSaleId], references: [id])
  amount           Decimal?        @db.Decimal(10, 2)
  createdById      Int?            @map("created_by_id")
  createdBy        Account?        @relation("CollectionsCreated", fields: [createdById], references: [id])
  isDeleted        Boolean         @default(false) @map("is_deleted")
  createdAt        DateTime        @default(now()) @map("created_at")

  @@map("collections")
}

model Expense {
  id          Int       @id @default(autoincrement())
  expense     String?   @db.VarChar(30)
  date        DateTime? @db.Date
  amount      Decimal?  @db.Decimal(10, 2)
  createdById Int?      @map("created_by_id")
  createdBy   Account?  @relation("ExpensesCreated", fields: [createdById], references: [id])
  isDeleted   Boolean   @default(false) @map("is_deleted")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("expenses")
}

model RentProduct {
  id         Int       @id @default(autoincrement())
  customerId Int?      @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id])
  stockId    Int?      @map("stock_id")
  stock      Stock?    @relation(fields: [stockId], references: [id], onDelete: Cascade)
  quantity   Int       @default(0)
  isDeleted  Boolean   @default(false) @map("is_deleted")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("rent_products")
}

model RentTransaction {
  id                   Int                 @id @default(autoincrement())
  customerId           Int                 @map("customer_id")
  customer             Customer            @relation(fields: [customerId], references: [id])
  stockId              Int                 @map("stock_id")
  stock                Stock               @relation(fields: [stockId], references: [id], onDelete: Cascade)
  saleId               Int?                @map("sale_id")
  sale                 Sale?               @relation(fields: [saleId], references: [id], onDelete: SetNull)
  commercialSaleItemId Int?                @map("commercial_sale_item_id")
  commercialSaleItem   CommercialSaleItem? @relation(fields: [commercialSaleItemId], references: [id], onDelete: SetNull)
  filledOut            Int                 @default(0) @map("filled_out")
  emptyIn              Int                 @default(0) @map("empty_in")
  createdAt            DateTime            @default(now()) @map("created_at")

  @@map("rent_transactions")
}

model ArbSale {
  id          Int         @id @default(autoincrement())
  trNo        String?     @map("tr_no") @db.VarChar(30)
  totalAmount Decimal?    @map("total_amount") @db.Decimal(10, 2)
  customerId  Int?        @map("customer_id")
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  paymentType PaymentType @default(cash) @map("payment_type")
  discount    Decimal?    @db.Decimal(10, 2)
  notes       String?
  createdById Int?        @map("created_by_id")
  createdBy   Account?    @relation("ArbSalesCreated", fields: [createdById], references: [id])
  isDeleted   Boolean     @default(false) @map("is_deleted")
  createdAt   DateTime    @default(now()) @map("created_at")
  paidAmount  Decimal     @default(0) @map("paid_amount") @db.Decimal(10, 2)

  items       ArbSaleItem[]
  collections Collection[]

  @@map("arb_sales")
}

model ArbSaleItem {
  id        Int      @id @default(autoincrement())
  arbSaleId Int      @map("arb_sale_id")
  arbSale   ArbSale  @relation(fields: [arbSaleId], references: [id], onDelete: Cascade)
  stockId   Int?     @map("stock_id")
  stock     Stock?   @relation(fields: [stockId], references: [id])
  productId Int?     @map("product_id")
  product   Product? @relation(fields: [productId], references: [id])
  quantity  Int      @default(0)
  salePrice Decimal? @map("sale_price") @db.Decimal(10, 2)
  netTotal  Decimal? @map("net_total") @db.Decimal(10, 2)

  @@map("arb_sale_items")
}

model CommercialSale {
  id          Int                  @id @default(autoincrement())
  trNo        String?              @map("tr_no") @db.VarChar(30)
  totalAmount Decimal?             @map("total_amount") @db.Decimal(10, 2)
  customerId  Int?                 @map("customer_id")
  customer    Customer?            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  paymentType PaymentType          @default(cash) @map("payment_type")
  discount    Decimal?             @db.Decimal(10, 2)
  notes       String?
  createdById Int?                 @map("created_by_id")
  createdBy   Account?             @relation("CommercialSalesCreated", fields: [createdById], references: [id])
  isDeleted   Boolean              @default(false) @map("is_deleted")
  createdAt   DateTime             @default(now()) @map("created_at")
  paidAmount  Decimal              @default(0) @map("paid_amount") @db.Decimal(10, 2)

  items       CommercialSaleItem[]
  collections Collection[]

  @@map("commercial_sales")
}

model CommercialSaleItem {
  id                   Int            @id @default(autoincrement())
  commercialSaleId     Int            @map("commercial_sale_id")
  commercialSale       CommercialSale @relation(fields: [commercialSaleId], references: [id], onDelete: Cascade)
  stockId              Int?           @map("stock_id")
  stock                Stock?         @relation(fields: [stockId], references: [id])
  productId            Int?           @map("product_id")
  product              Product?       @relation(fields: [productId], references: [id])
  saleType             SaleType       @default(rent) @map("sale_type")
  quantity             Int            @default(0)
  salePrice            Decimal?       @map("sale_price") @db.Decimal(10, 2)
  netTotal             Decimal?       @map("net_total") @db.Decimal(10, 2)
  cylindersDispatched  Int            @default(0) @map("cylinders_dispatched")
  cylindersReturned    Int            @default(0) @map("cylinders_returned")

  rentTransactions RentTransaction[]

  @@map("commercial_sale_items")
}

model CustomerInitialCylinderBalance {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  Int      @map("product_id")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([customerId, productId])
  @@map("customer_initial_cylinder_balances")
}

model Vendor {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  phone     String?  @db.VarChar(20)
  address   String?
  gstNumber String?  @map("gst_number") @db.VarChar(15)
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")

  purchases Purchase[]
  stocks    Stock[]

  @@map("vendors")
}

model Purchase {
  id           Int      @id @default(autoincrement())
  invoiceNo    String?  @unique @map("invoice_no") @db.VarChar(50)
  vendorId     Int      @map("vendor_id")
  vendor       Vendor   @relation(fields: [vendorId], references: [id])
  totalAmount  Decimal? @map("total_amount") @db.Decimal(10, 2)
  purchaseDate DateTime @default(now()) @map("purchase_date")
  notes        String?
  isDeleted    Boolean  @default(false) @map("is_deleted")
  createdAt    DateTime @default(now()) @map("created_at")

  items  PurchaseItem[]
  stocks Stock[]

  @@map("purchases")
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int      @map("purchase_id")
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  Int      @map("product_id")
  product    Product  @relation(fields: [productId], references: [id])
  batchNo    String   @map("batch_no") @db.VarChar(50)
  quantity   Int      @default(0)
  unitCost   Decimal? @map("unit_cost") @db.Decimal(10, 2)
  totalCost  Decimal? @map("total_cost") @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("purchase_items")
}
